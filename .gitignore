# ==========================================
# Private Environment & API Credentials
# ==========================================
.env
# Catch any secrets.h file, specifically the one in ./esp32
secrets.h

# ==========================================
# Webhook Private Configuration
# ==========================================
erg-backend-hook.json

# ==========================================
# Python Internal Caches
# ==========================================
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/

# ==========================================
# Docker Volume Data & Local Caches
# ==========================================
# Ignore all live workout history data and generated stats
/data/*
/www/*

# Explicitly whitelist the tracking anchors so empty folders exist on GitHub
!/data/.gitkeep
!/www/.gitkeep

# ==========================================
# Hardware / ESP32 Build Artifacts
# ==========================================
# Ignore local compilation files generated by Arduino IDE / VSCode inside ./esp32
/esp32/build/
/esp32/local_build/
*.bin
*.elf
*.hex

# ==========================================
# System & Editor Trash
# ==========================================
.DS_Store
Thumbs.db
.vscode/
.idea/
*.swp
*~
